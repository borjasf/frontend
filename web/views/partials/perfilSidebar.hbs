<div class="col-lg-3 mb-4">
    <div class="card shadow-sm border-0">
        <div class="card-body text-center pt-4 pb-4 border-bottom">
            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="fa-solid fa-user fs-1"></i>
            </div>
            <h5 class="fw-bold mb-0">{{usuario.nombre}} {{usuario.apellidos}}</h5>
            <p class="text-muted small">{{usuario.email}}</p>
        </div>
        <div class="list-group list-group-flush">
            <a href="/perfil" class="list-group-item list-group-item-action {{#if activoPerfil}}active fw-bold{{/if}} py-3">
                <i class="fa-solid fa-id-card me-2"></i> Mis Datos
            </a>
            <a href="/perfil/mis-ventas" class="list-group-item list-group-item-action {{#if activoVentas}}active fw-bold{{/if}} py-3">
                <i class="fa-solid fa-store me-2"></i> En Venta / Vendidos
            </a>
            <a href="/perfil/mis-compras" class="list-group-item list-group-item-action {{#if activoCompras}}active fw-bold{{/if}} py-3">
                <i class="fa-solid fa-bag-shopping me-2"></i> Mis Compras
            </a>
            <a href="/logout" class="list-group-item list-group-item-action text-danger py-3 fw-bold bg-light">
                <i class="fa-solid fa-right-from-bracket me-2"></i> Cerrar Sesión
            </a>
        </div>
    </div>
</div>

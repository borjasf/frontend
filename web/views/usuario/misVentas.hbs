{{!-- Página "Mis ventas".
      Lista todos los productos que el usuario autenticado ha vendido:
      título, precio, comprador y fecha de venta.
      Datos obtenidos via GET /api/compraventas/ventas/:idVendedor --}}
<div class="container mt-5 mb-5">
    <div class="row">
        
        {{!-- Reutilizamos el sidebar del perfil para mantener la consistencia visual --}}
        {{> perfilSidebar}}

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">Historial de Ventas</h2>
                <a href="/productos/crear" class="btn btn-success"><i class="fa-solid fa-plus me-2"></i>Publicar Nuevo</a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="ps-4">Título</th>
                                    <th scope="col">Precio</th>
                                    <th scope="col">Comprador</th>
                                    <th scope="col">Fecha</th>
                                    <th scope="col" class="text-end pe-4">Detalle</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each ventas}}
                                <tr>
                                    <td class="ps-4 fw-bold">{{this.titulo}}</td>
                                    <td>{{this.precio}} €</td>
                                    <td>{{this.comprador}}</td>
                                    <td class="text-muted small">{{this.fecha}}</td>
                                    <td class="text-end pe-4">
                                        <a href="/productos/{{this.idProducto}}" class="btn btn-sm btn-outline-primary" title="Ver producto">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </a>
                                    </td>
                                </tr>
                                {{else}}
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Aún no has realizado ninguna venta.</td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<link rel="stylesheet" href="/css/login.css">

<main>
    <div class="login-card">

        {{!-- Cabecera con logo --}}
        <div class="login-header">
            <img src="/img/logo.png" alt="Logo" width="200" height="100">
            <h1>Bienvenido</h1>
            <p>Inicia sesión en tu cuenta para continuar</p>
        </div>

        {{!-- Mensaje de error enviado desde el servidor --}}
        {{#if error}}
            <p style="color: #ef4444; font-size: 0.875rem; text-align: center; margin-bottom: 1rem;">{{error}}</p>
        {{/if}}

        <form action="/login" method="POST">

            {{!-- Email --}}
            <div class="form-group">
                <label for="email">Correo electrónico *</label>
                <input type="email" id="email" name="email" required>
            </div>

            {{!-- Contraseña --}}
            <div class="form-group">
                <label for="password">Contraseña *</label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" required>
                    <button type="button" class="toggle-password" onclick="togglePassword()">👁</button>
                </div>
            </div>

            {{!-- Botones --}}
            <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem;">
                <button type="submit" class="btn-login">
                    <span class="transition"></span>
                    <span class="gradient"></span>
                    <span class="label">Iniciar sesión</span>
                </button>
                <a href="/" class="btn-cancel">Cancelar</a>
            </div>

        	<div class="social-message">
		<div class="line"></div>
		<p class="message">Login with social accounts</p>
		<div class="line"></div>
     </div>

        <div class="social-icons">
            <button aria-label="Log in with GitHub" class="icon" onclick="window.location.href='/auth/github'">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-5 h-5 fill-current">
                    <path d="M16 0.396c-8.839 0-16 7.167-16 16 0 7.073 4.584 13.068 10.937 15.183 0.803 0.151 1.093-0.344 1.093-0.772 0-0.38-0.009-1.385-0.015-2.719-4.453 0.964-5.391-2.151-5.391-2.151-0.729-1.844-1.781-2.339-1.781-2.339-1.448-0.989 0.115-0.968 0.115-0.968 1.604 0.109 2.448 1.645 2.448 1.645 1.427 2.448 3.744 1.74 4.661 1.328 0.14-1.031 0.557-1.74 1.011-2.135-3.552-0.401-7.287-1.776-7.287-7.907 0-1.751 0.62-3.177 1.645-4.297-0.177-0.401-0.719-2.031 0.141-4.235 0 0 1.339-0.427 4.4 1.641 1.281-0.355 2.641-0.532 4-0.541 1.36 0.009 2.719 0.187 4 0.541 3.043-2.068 4.381-1.641 4.381-1.641 0.859 2.204 0.317 3.833 0.161 4.235 1.015 1.12 1.635 2.547 1.635 4.297 0 6.145-3.74 7.5-7.296 7.891 0.556 0.479 1.077 1.464 1.077 2.959 0 2.14-0.020 3.864-0.020 4.385 0 0.416 0.28 0.916 1.104 0.755 6.4-2.093 10.979-8.093 10.979-15.156 0-8.833-7.161-16-16-16z"></path>
                </svg>
            </button>
        </div>

            {{!-- Enlace al registro --}}
            <p class="register-link">
                ¿No tienes una cuenta?
                <a href="/registro">Regístrate aquí</a>.
            </p>

        </form>
    </div>
</main>

<script>
    function togglePassword() {
        const input = document.getElementById('password');
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>

{{!-- Página de registro (opcional, valorado en la práctica).
      Formulario con campos nombre, apellidos, email y contraseña que hace POST /registro.
      Muestra errores de validación si el email ya existe u otros errores de la API. --}}

<link rel="stylesheet" href="/css/registro.css">

<main>
    <div class="registro-card">

        {{!-- Cabecera con logo --}}
        <div class="registro-header">
            <img src="/img/logo.png" alt="Logo" width="200" height="100">
            <h1>Crear cuenta</h1>
            <p>Regístrate para acceder a tu cuenta</p>
        </div>

        {{!-- Mensaje de error enviado desde el servidor --}}
        {{#if error}}
            <p style="color: #ef4444; font-size: 0.875rem; text-align: center; margin-bottom: 1rem;">{{error}}</p>
        {{/if}}

        <form action="/registro" method="POST">

            {{!-- Nombre --}}
            <div class="form-group">
                <label for="nombre">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required>
            </div>

            {{!-- Apellidos --}}
            <div class="form-group">
                <label for="apellidos">Apellidos *</label>
                <input type="text" id="apellidos" name="apellidos" required>
            </div>

            {{!-- Email --}}
            <div class="form-group">
                <label for="email">Correo electrónico *</label>
                <input type="email" id="email" name="email" required>
            </div>

            {{!-- Contraseña --}}
            <div class="form-group">
                <label for="password">Contraseña *</label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" required oninput="checkPasswords()">
                    <button type="button" class="toggle-password" onclick="togglePassword(this, 'password')">👁</button>
                </div>
            </div>

            {{!-- Repetir contraseña --}}
            <div class="form-group">
                <label for="confirmPassword">Confirmar contraseña *</label>
                <div class="password-wrapper">
                    <input type="password" id="confirmPassword" name="confirmPassword" required oninput="checkPasswords()">
                    <button type="button" class="toggle-password" onclick="togglePassword(this, 'confirmPassword')">👁</button>
                </div>

            </div>

            {{!-- Fecha de nacimiento --}}

            <div class="form-group">
                <label for="fechaNacimiento">Fecha de nacimiento</label>
                <input type="date" id="fechaNacimiento" name="fechaNacimiento">
            </div>

            {{!-- Is Admin --}}
            <div class="form-group checkbox-group">
                <span class="checkbox-label">¿Es administrador?</span>
                <div class="cbx-wrapper">
                    <input type="checkbox" id="isAdmin" name="isAdmin">
                    <label for="isAdmin" class="cbx">
                        <div class="flip">
                            <div class="front"></div>
                            <div class="back">
                                <svg viewBox="0 0 16 14" height="14" width="16">
                                    <path d="M2 8.5L6 12.5L14 1.5"></path>
                                </svg>
                            </div>
                        </div>
                    </label>
                </div>
            </div>

            {{!-- Botón de registro --}}
             <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem;">
                <button type="submit" class="btn-register">
                    <span class="transition"></span>
                    <span class="gradient"></span>
                    <span class="label">Registrarse</span>
                </button>
                <a href="/login" class="btn-cancel">Cancelar</a>
            </div>

        </form>
    </div>
</main>

<script>
    function togglePassword(btn, id) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        btn.textContent = input.type === 'password' ? '👁' : '👁';
    }

    function checkPasswords() {
        const pwd = document.getElementById('password').value;
        const confirm = document.getElementById('confirmPassword').value;
        document.getElementById('confirmPassword').setCustomValidity(confirm && pwd !== confirm ? 'Las contraseñas no coinciden.' : '');
    }
</script>

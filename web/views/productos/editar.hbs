{{!-- Formulario para editar un producto existente (solo el vendedor).
      Solo permite modificar precio y descripción (limitación de la API ArSo: PATCH /api/productos/:id).
      Hace POST /productos/:id con los nuevos valores. --}}
<div class="container mt-5 mb-5">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0 text-center">Editar Producto</h4>
                </div> 
                  {{!-- En el formulario se verán todos los campos del productos y además dos 
                  editables con el precio y la descripción --}}
                  <div class="card-body p-4">

                    {{!-- Datos de solo lectura --}}
                    <h6 class="text-muted mb-3">Información del producto</h6>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Título</label>
                        <input type="text" class="form-control bg-light" value="{{producto.titulo}}" disabled>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Estado</label>
                            <input type="text" class="form-control bg-light" value="{{producto.estado}}" disabled>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Categoría</label>
                            <input type="text" class="form-control bg-light" value="{{producto.categoria.nombre}}" disabled>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Fecha de publicación</label>
                            <input type="text" class="form-control bg-light" value="{{producto.fechaPublicacion}}" disabled>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Visualizaciones</label>
                            <input type="text" class="form-control bg-light" value="{{producto.visualizaciones}}" disabled>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Lugar de recogida</label>
                        <input type="text" class="form-control bg-light" value="{{producto.lugarRecogida}}" disabled>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Envío disponible</label>
                        <input type="text" class="form-control bg-light" value="{{#if producto.envioDisponible}}Sí{{else}}No{{/if}}" disabled>
                    </div>

                    <hr class="my-4">
                    <h6 class="text-muted mb-3">Campos editables</h6>

                    {{!-- Campos editables --}}
                    <form action="/productos/{{producto.id}}/editar" method="POST">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Precio</label>
                            <div class="input-group">
                                <input type="number" step="0.01" class="form-control" name="precio" value="{{producto.precio}}" required>
                                <span class="input-group-text">€</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Descripción</label>
                            <textarea class="form-control" name="descripcion" rows="4" required>{{producto.descripcion}}</textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark flex-grow-1">Guardar cambios</button>
                            <a href="/productos/{{producto.id}}" class="btn btn-outline-secondary">Cancelar</a>
                        </div>

                    </form>
                  </div>
            </div>
        </div>
      </div>
</div>


{{!-- Formulario para publicar un nuevo producto (requiere estar autenticado).
      Campos: título, descripción, precio, estado (nuevo/usado), categoría (select cargado desde API), envío disponible.
      Hace POST /productos. El idVendedor se toma del usuario en sesión en el servidor. --}}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h4 class="mb-0 text-center">Publicar en Segundum</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/productos/crear" method="POST">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">¿Qué vendes?</label>
                            <input type="text" class="form-control" name="titulo" required placeholder="Ej: PlayStation 5 impecable">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Precio</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control" name="precio" required>
                                    <span class="input-group-text">€</span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Categoría</label>
                                <select class="form-select" name="categoria" required>
                                    <option value="" disabled selected>Cargando categorías...</option>
                                    {{#each categorias}}
                                        <option value="{{this.id}}">{{this.nombre}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Estado del producto</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="estado" id="nuevo" value="NUEVO" checked>
                                    <label class="form-check-label" for="nuevo">Nuevo</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="estado" id="usado" value="USADO">
                                    <label class="form-check-label" for="usado">Usado</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Descripción</label>
                            <textarea class="form-control" name="descripcion" rows="3" required></textarea>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" id="envio" name="envioDisponible">
                            <label class="form-check-label" for="envio">Ofrezco envío a domicilio</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark btn-lg">Publicar anuncio</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>